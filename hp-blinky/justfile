###### LINTING ######

cargo-format:
  #!/usr/bin/env bash
  shopt -s globstar 
  cargo fmt --all -- --config-path=rustfmt.toml src/**/*.rs

cargo-clippy:
  #!/usr/bin/env bash
  echo "Hard-coded for esp32s3 chip!" >&2
  cargo clippy --features=esp32s3 --target xtensa-esp32s3-none-elf -- -D warnings --no-deps
